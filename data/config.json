{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "openrouter/elephant-alpha",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "languages": ["zh", "en"]
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "The Diplomat",
        "url": "https://thediplomat.com/feed/",
        "enabled": true,
        "category": "indo-pacific"
      },
      {
        "name": "DW English",
        "url": "https://rss.dw.com/rdf/rss-en-all",
        "enabled": true,
        "category": "world-news"
      },
      {
        "name": "BBC World",
        "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
        "enabled": true,
        "category": "world-news"
      },
      {
        "name": "RFI International",
        "url": "https://www.rfi.fr/en/international/rss",
        "enabled": true,
        "category": "world-news"
      },
      {
        "name": "Financial Times World",
        "url": "https://www.ft.com/world?format=rss",
        "enabled": true,
        "category": "global-economy"
      },
      {
        "name": "Foreign Policy",
        "url": "https://foreignpolicy.com/feed/",
        "enabled": true,
        "category": "foreign-policy"
      },
      {
        "name": "Nikkei Asia",
        "url": "https://asia.nikkei.com/rss/feed/nar",
        "enabled": true,
        "category": "asia-economy"
      },
      {
        "name": "WSJ World News",
        "url": "https://feeds.a.dj.com/rss/RSSWorldNews.xml",
        "enabled": true,
        "category": "world-news"
      },
      {
        "name": "POLITICO Europe Trade",
        "url": "https://www.politico.eu/section/trade/feed/",
        "enabled": true,
        "category": "trade-policy"
      },
      {
        "name": "POLITICO Europe Energy",
        "url": "https://www.politico.eu/section/energy/feed/",
        "enabled": true,
        "category": "energy-security"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  }
}
