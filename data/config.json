{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "google/gemma-4-31b-it",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "languages": ["zh", "en"]
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "The Diplomat",
        "url": "https://thediplomat.com/feed/",
        "enabled": true,
        "category": "indo-pacific"
      },
      {
        "name": "DW English",
        "url": "https://rss.dw.com/rdf/rss-en-all",
        "enabled": true,
        "category": "world-news"
      },
      {
        "name": "BBC World",
        "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
        "enabled": true,
        "category": "world-news"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "geopolitics",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 20
        },
        {
          "subreddit": "CredibleDefense",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 40
        },
        {
          "subreddit": "ForeignPolicy",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  }
}